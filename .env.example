# ============================================================
# WordPress ローカル開発用 環境変数
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
# ============================================================

# ---- 公開ポート / デバッグ ----
WP_PORT=8080
WORDPRESS_DEBUG=1

# ---- WordPress から接続する DB 情報 ----
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress

# ---- MariaDB(MySQL) サーバー設定 ----
MYSQL_ROOT_PASSWORD=root

# ---- テーブル接頭辞 ----
WORDPRESS_TABLE_PREFIX=wp_

# ---- wp-cli での自動インストール用 ----
WP_URL=http://localhost:8080
WP_TITLE=Shino Music School
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=admin
WP_ADMIN_EMAIL=admin@example.com

# ---- 有効化するテーマ（themes/ 配下のディレクトリ名）----
WP_THEME=shino-music-school
